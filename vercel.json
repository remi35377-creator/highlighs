{
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/index.py" },
    { "source": "/api/history/(.*)", "destination": "/api/index.py" },
    { "source": "/api/upload", "destination": "/api/index.py" },
    { "source": "/api/highlights/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}